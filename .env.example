# .env.example — committed to git, shows variable NAMES only
# Copy this to .env (gitignored) and fill in real values.
#
# Rule: committed files may reference variables but must NEVER contain real secrets.
# Pattern: use ${VAR:-inert-placeholder} in docker-compose.yml and scripts.

# ==============================================================================
# App
# ==============================================================================
NODE_ENV=development
PORT=3000

# ==============================================================================
# GitHub
# ==============================================================================
# tsd-curriculum-deploy PAT — set in local .env, never commit a real value here
GITHUB_TOKEN=set-in-env-file

# ==============================================================================
# Database (uncomment when needed)
# ==============================================================================
# DATABASE_URL=postgres://postgres:change-me-local-password@db:5432/dev

# ==============================================================================
# Third-party APIs (uncomment when needed)
# ==============================================================================
# Stripe (keep test keys in .env, NEVER here)
# STRIPE_SECRET_KEY=set-in-env-file
# STRIPE_PUBLISHABLE_KEY=set-in-env-file

# Supabase
# SUPABASE_URL=set-in-env-file
# SUPABASE_ANON_KEY=set-in-env-file
# SUPABASE_SERVICE_ROLE_KEY=set-in-env-file
